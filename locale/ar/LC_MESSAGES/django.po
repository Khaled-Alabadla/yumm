# ---------------------------------------------------------------------------
# accounts/permissions.py + accounts/decorators.py
# ---------------------------------------------------------------------------

msgid "Admin access required."
msgstr "مطلوب صلاحيات المدير."

msgid "Owner access required."
msgstr "مطلوب صلاحيات المالك."

msgid "Admin or Owner access required."
msgstr "مطلوب صلاحيات المدير أو المالك."

msgid "You do not have permission to perform this action."
msgstr "ليس لديك إذن لتنفيذ هذا الإجراء."

# ---------------------------------------------------------------------------
# accounts/views.py
# ---------------------------------------------------------------------------

msgid "Create Account"
msgstr "إنشاء حساب"

msgid "Registration successful. Please log in."
msgstr "تم التسجيل بنجاح. يرجى تسجيل الدخول."

msgid "Registration failed. Please correct the errors below."
msgstr "فشل التسجيل. يرجى تصحيح الأخطاء أدناه."

msgid "Sign In"
msgstr "تسجيل الدخول"

msgid "Login successful."
msgstr "تم تسجيل الدخول بنجاح."

msgid "Invalid credentials."
msgstr "بيانات الاعتماد غير صحيحة."

msgid "Logged out successfully."
msgstr "تم تسجيل الخروج بنجاح."

msgid "My Profile"
msgstr "ملفي الشخصي"

msgid "Profile updated successfully."
msgstr "تم تحديث الملف الشخصي بنجاح."

msgid "Profile update failed. Please correct the errors below."
msgstr "فشل تحديث الملف الشخصي. يرجى تصحيح الأخطاء أدناه."

msgid "Demo login is only available in DEBUG mode."
msgstr "تسجيل الدخول التجريبي متاح فقط في وضع التصحيح."

msgid "Invalid demo role."
msgstr "دور تجريبي غير صالح."

msgid "Logged in as demo %(role)s account."
msgstr "تم تسجيل الدخول كحساب %(role)s التجريبي."
