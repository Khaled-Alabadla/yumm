# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# MySQL
MYSQL_DATABASE=yumm_db
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# Public site URL used in email links (no trailing slash)
# Local:  http://127.0.0.1:8000
# AWS:    https://your-domain-or-ec2-url
SITE_URL=http://127.0.0.1:8000

# ---------------------------------------------------------------------------
# Email — Gmail SMTP (works locally AND on AWS, no custom domain needed)
#
# Setup (once):
#   1. Enable 2-Step Verification on your Google account
#   2. Create an App Password: Google Account → Security → App passwords
#   3. Put the 16-character app password in EMAIL_HOST_PASSWORD (no spaces)
#
# Optional local-only (print emails to the terminal instead of sending):
#   EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# ---------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=yourname@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=Yumm <yourname@gmail.com>

# AI Assistant (optional — chat works without it using database replies)
# Get a key at https://api.together.xyz/
TOGETHER_API_KEY=
