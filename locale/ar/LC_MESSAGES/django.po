# accounts/managers.py
# ---------------------------------------------------------------------------

msgid "The email address must be set."
msgstr "يجب تعيين عنوان البريد الإلكتروني."

msgid "Superuser must have is_staff=True."
msgstr "يجب أن يكون للمشرف العام is_staff=True."

msgid "Superuser must have is_superuser=True."
msgstr "يجب أن يكون للمشرف العام is_superuser=True."

